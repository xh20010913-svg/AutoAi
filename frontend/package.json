{
  "name": "autoai-desktop",
  "version": "0.2.0",
  "description": "AutoAI - Local autonomous agent management desktop app",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "start": "npm run build && electron .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.6.0",
    "lucide-react": "^0.507.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "vite": "^6.3.0",
    "tailwindcss": "^4.1.0",
    "@tailwindcss/vite": "^4.1.0",
    "typescript": "~5.8.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  },
  "build": {
    "appId": "com.autoai.desktop",
    "productName": "AutoAI",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "../autoai/**/*"
    ],
    "extraResources": [
      {
        "from": "../autoai",
        "to": "autoai",
        "filter": ["**/*"]
      }
    ]
  }
}
